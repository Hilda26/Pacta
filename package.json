{
  "name": "pacta",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm --filter @pacta/frontend dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "e2e": "pnpm --filter @pacta/e2e test",
    "db:validate": "pnpm --filter @pacta/database typecheck",
    "db:migrate": "pnpm --filter @pacta/database migrate:instructions"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@next/eslint-plugin-next": "^15.5.20",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "globals": "^17.7.0",
    "next": "15.5.20",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.62.1"
  }
}
